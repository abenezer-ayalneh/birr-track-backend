{
	"name": "nest-template",
	"version": "0.0.1",
	"description": "Template for NestJS project",
	"author": "Ablaze Labs",
	"private": true,
	"license": "UNLICENSED",
	"scripts": {
		"build": "nest build",
		"format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
		"start": "nest start",
		"start:dev": "nest start --watch",
		"start:debug": "nest start --debug --watch",
		"start:prod": "node dist/main",
		"lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
		"test": "jest",
		"test:watch": "jest --watch",
		"test:cov": "jest --coverage",
		"test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
		"test:e2e": "jest --config ./test/jest-e2e.json",
		"test:smoke:e2e": "ts-node src/scripts/smoke-test-e2e.ts",
		"test:smoke:e2e:wait": "SMOKE_WAIT_FOR_BACKEND_MS=120000 SMOKE_TIMEOUT_MS=120000 ts-node src/scripts/smoke-test-e2e.ts",
		"smoke:e2e": "ts-node src/scripts/smoke-test-e2e.ts",
		"smoke:e2e:wait": "SMOKE_WAIT_FOR_BACKEND_MS=120000 SMOKE_TIMEOUT_MS=120000 ts-node src/scripts/smoke-test-e2e.ts",
		"db:migrate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli -d src/database/data-source.ts migration:run",
		"smoke:e2e:setup": "npm run db:migrate && npm run smoke:e2e:wait",
		"pretty-quick": "pretty-quick --staged",
		"lint-staged": "lint-staged",
		"prepare": "husky"
	},
	"dependencies": {
		"@nestjs/common": "^11.1.13",
		"@nestjs/config": "^4.0.3",
		"@nestjs/core": "^11.1.13",
		"@nestjs/platform-express": "^11.1.13",
		"@nestjs/platform-socket.io": "^11.1.17",
		"@nestjs/swagger": "^11.2.6",
		"@nestjs/throttler": "^6.5.0",
		"@nestjs/typeorm": "^11.0.0",
		"@nestjs/websockets": "^11.1.17",
		"@prisma/client": "^7.3.0",
		"axios": "^1.14.0",
		"bullmq": "^5.72.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.14.3",
		"exceljs": "^4.4.0",
		"form-data": "^4.0.5",
		"helmet": "^8.1.0",
		"ioredis": "^5.10.1",
		"nest-winston": "^1.10.2",
		"pg": "^8.20.0",
		"reflect-metadata": "^0.2.2",
		"nestjs-telegraf": "^2.9.1",
		"rxjs": "^7.8.2",
		"socket.io": "^4.8.3",
		"telegraf": "^4.16.3",
		"typeorm": "^0.3.28",
		"winston": "^3.19.0",
		"winston-daily-rotate-file": "^5.0.0"
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.1",
		"@commitlint/config-conventional": "^20.4.1",
		"@commitlint/types": "^20.4.0",
		"@eslint/js": "^9.39.2",
		"@nestjs/cli": "^11.0.16",
		"@nestjs/schematics": "^11.0.9",
		"@nestjs/testing": "^11.1.13",
		"@types/express": "^5.0.6",
		"@types/jest": "^30.0.0",
		"@types/node": "^25.2.0",
		"@types/supertest": "^6.0.3",
		"@typescript-eslint/eslint-plugin": "^8.54.0",
		"@typescript-eslint/parser": "^8.54.0",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-prettier": "^5.5.5",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"eslint-plugin-unused-imports": "^4.3.0",
		"globals": "^17.3.0",
		"husky": "^9.1.7",
		"jest": "^30.2.0",
		"lint-staged": "^16.2.7",
		"prettier": "^3.8.1",
		"pretty-quick": "^4.2.2",
		"prisma": "^7.3.0",
		"prismixer": "^1.0.4",
		"source-map-support": "^0.5.21",
		"supertest": "^7.2.2",
		"ts-jest": "^29.4.6",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0"
	},
	"jest": {
		"moduleFileExtensions": [
			"js",
			"json",
			"ts"
		],
		"rootDir": "src",
		"testRegex": ".*\\.spec\\.ts$",
		"transform": {
			"^.+\\.(t|j)s$": "ts-jest"
		},
		"collectCoverageFrom": [
			"**/*.(t|j)s"
		],
		"coverageDirectory": "../coverage",
		"testEnvironment": "node"
	}
}
