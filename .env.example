#App
PORT=3000
APP_BASE_URL="http://localhost:${PORT}"
NODE_ENVIRONMENT=development
NODE_VERSION=20.11.0
CORS_ALLOWED_ORIGINS='http://localhost:4200,http://localhost:4371'
FRONTEND_APP_URL=http://localhost:4200

#Throttle
THROTTLER_TTL=60000
THROTTLER_LIMIT=10

#Database
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=birr_track
DATABASE_URL="postgresql://${DATABASE_USER}:${DATABASE_PASSWORD}@${DATABASE_HOST}:${DATABASE_PORT}/${DATABASE_NAME}?schema=public"

#Redis
REDIS_HOST=localhost
REDIS_PORT=6379

#OCR
OCR_SERVICE_URL=http://localhost:8000

#LLM
# Local FastAPI llm endpoint: POST ${LLM_SERVICE_URL}/llm/extract
LLM_SERVICE_URL=http://localhost:8000

#Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_WEBHOOK_BASE_URL=

#Testing
SMOKE_APP_BASE_URL=
SMOKE_WAIT_FOR_BACKEND_MS=120000
SMOKE_TELEGRAM_FILE_ID=
SMOKE_TIMEOUT_MS=120000
